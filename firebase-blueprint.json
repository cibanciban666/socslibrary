{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Represents a book in the library",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "available": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "category", "stock", "available", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a book circulation transaction",
      "type": "object",
      "properties": {
        "bookId": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "borrowerName": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["bookId", "type", "quantity", "date"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Collection of books"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Collection of transactions"
    }
  }
}
